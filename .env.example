# Required only for AI letter/agreement generation.
GEMINI_API_KEY=""

# Override only when intentionally using another supported Gemini model.
GEMINI_MODEL="gemini-3.5-flash"

PORT="3000"

# Persistent runtime storage for VAPID keys and scheduled notifications.
DATA_DIR="./runtime-data"

# Replace with an email address or HTTPS origin you control in production.
VAPID_SUBJECT="mailto:admin@example.com"
