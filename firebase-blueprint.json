{
  "entities": {
    "user_data": {
      "title": "User Data",
      "description": "User specific data like history",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "description": "List of order history items"
        }
      },
      "required": ["items"]
    }
  },
  "firestore": {
    "/users/{userId}/data/history": {
      "schema": "user_data",
      "description": "User order history"
    }
  }
}
