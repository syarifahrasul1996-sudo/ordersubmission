{
  "name": "order-submission-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "smoke": "node scripts/smoke-server.mjs",
    "check": "npm run lint && npm test && npm run build && node --check apps-script.js && node --check public/sw.js && npm run smoke"
  },
  "dependencies": {
  "clsx": "^2.1.1",
  "firebase": "^12.14.0",
  "lucide-react": "^0.546.0",
  "motion": "^12.23.24",
  "react": "^19.0.1",
  "react-dom": "^19.0.1",
  "recharts": "^3.8.1",
  "tailwind-merge": "^3.6.0"
},
"devDependencies": {
  "@tailwindcss/vite": "^4.3.1",
  "@vitejs/plugin-react": "^5.2.0",
  "typescript": "~5.8.3",
  "vite": "^6.4.3"
},
  "engines": {
    "node": ">=20.0.0"
  }
}
